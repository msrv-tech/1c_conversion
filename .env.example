# Конфигурация подключений к базам данных 1С
# Скопируйте этот файл в .env и заполните реальными значениями

# Формат строки подключения для файловых баз
# File="путь";Usr=;Pwd=;

# Формат строки подключения для серверных баз
# Srvr="сервер";Ref="имя_базы";Usr=;Pwd=;

# ИСТОЧНИК (Source) - строка подключения к базе-источнику
SOURCE_CONNECTION_STRING=

# ПРИЕМНИК (Target) - строка подключения к базе-приемнику
TARGET_CONNECTION_STRING=
